# API base URL for the dashboard/auth requests.
# Unset -> falls back to prod (https://api.nexara.ru) in code.
#
#   local        http://localhost:8000
#   test server  http://api.test.nexara.ru
#   prod         https://api.nexara.ru
#
# Local dev: copy this file to `.env`. On servers, set it in the
# docker-compose `dashboard` service `environment:` block instead.
PUBLIC_API_BASE_URL=http://localhost:8000
